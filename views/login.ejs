<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content="Secure login to Aegis AI - Your Proactive Productivity Companion." />
  <title>Aegis AI - Secure Access Login</title>
  <link rel="stylesheet" href="/css/index.css">
  <link rel="stylesheet" href="/css/app.css">
  <style>
    .login-container {
      display: flex;
      align-items: center;
      justify-content: center;
      width: 100%;
      height: 100%;
      padding: 1.5rem;
    }
    
    .login-card {
      width: 100%;
      max-width: 420px;
      padding: 2.5rem 2rem;
      text-align: center;
      box-shadow: 0 15px 35px rgba(0, 0, 0, 0.6);
      animation: cardFadeIn 0.6s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    }
    
    @keyframes cardFadeIn {
      from {
        opacity: 0;
        transform: translateY(20px);
      }
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }
    
    .login-logo {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 0.75rem;
      margin-bottom: 2rem;
      text-decoration: none;
    }
    
    .login-logo .logo-icon {
      width: 2.5rem;
      height: 2.5rem;
      font-size: 1.4rem;
      border-radius: 0.6rem;
    }
    
    .login-logo .logo-text {
      font-size: 1.6rem;
    }
    
    .login-header {
      margin-bottom: 1.75rem;
    }
    
    .login-header h2 {
      font-family: 'Space Grotesk', sans-serif;
      font-size: 1.4rem;
      font-weight: 700;
      color: #ffffff;
      margin-bottom: 0.25rem;
    }
    
    .login-header p {
      font-size: 0.8rem;
      color: var(--text-secondary);
    }
    
    .error-banner {
      background: rgba(239, 68, 68, 0.12);
      border: 1px solid rgba(239, 68, 68, 0.25);
      border-left: 4px solid var(--accent-red);
      color: #fca5a5;
      padding: 0.75rem 1rem;
      border-radius: 0.5rem;
      font-size: 0.8rem;
      text-align: left;
      margin-bottom: 1.5rem;
      display: flex;
      align-items: center;
      gap: 0.5rem;
      animation: bannerSlideIn 0.3s ease-out;
    }
    
    @keyframes bannerSlideIn {
      from { transform: scaleY(0.8); opacity: 0; }
      to { transform: scaleY(1); opacity: 1; }
    }
    
    .login-form {
      display: flex;
      flex-direction: column;
      gap: 1.25rem;
      text-align: left;
    }
    
    .form-group label {
      margin-bottom: 0.4rem;
    }
    
    .form-options {
      display: flex;
      align-items: center;
      justify-content: space-between;
      font-size: 0.75rem;
      color: var(--text-secondary);
      margin-top: -0.25rem;
    }
    
    .checkbox-label {
      display: flex;
      align-items: center;
      gap: 0.5rem;
      cursor: pointer;
    }
    
    .checkbox-label input[type="checkbox"] {
      accent-color: var(--accent-cyan);
      cursor: pointer;
    }
    
    .forgot-link {
      color: var(--accent-cyan);
      text-decoration: none;
      transition: opacity 0.2s ease;
    }
    
    .forgot-link:hover {
      opacity: 0.8;
      text-shadow: var(--glow-cyan);
    }
    
    .signup-prompt {
      margin-top: 1.5rem;
      font-size: 0.75rem;
      color: var(--text-secondary);
    }
    
    .signup-prompt a {
      color: var(--accent-indigo);
      text-decoration: none;
      font-weight: 600;
      transition: color 0.2s ease;
    }
    
    .signup-prompt a:hover {
      color: var(--accent-cyan);
    }
  </style>
</head>
<body>
  <div class="app-container">
    <div class="ambient-glow-1"></div>
    <div class="ambient-glow-2"></div>

    <div class="login-container">
      <div class="glass-card login-card">
        <!-- Logo Header -->
        <div class="login-logo">
          <div class="logo-icon">A</div>
          <span class="logo-text">Aegis AI</span>
        </div>

        <div class="login-header">
          <h2>Welcome Back</h2>
          <p>Sign in to resume scheduling your focus feed</p>
        </div>

        <!-- Dynamic Server-side Auth Error Banner -->
        <% if (typeof error !== 'undefined' && error) { %>
          <div class="error-banner">
            <span>⚠️</span>
            <span><%= error %></span>
          </div>
        <% } %>

        <!-- Login Form -->
        <form action="/login" method="POST" class="login-form">
          <div class="form-group">
            <label for="username">Username or Email</label>
            <input 
              type="email" 
              name="email" 
              id="username" 
              placeholder="e.g. you@gmail.com" 
              class="form-input" 
              required
              value="<%= typeof username !== 'undefined' ? username : '' %>"
            />
          </div>

          <div class="form-group">
            <label for="password">Password</label>
            <input 
              type="password" 
              name="password" 
              id="password" 
              placeholder="••••••••" 
              class="form-input" 
              required
            />
          </div>

          <div class="form-options">
            <label class="checkbox-label">
              <input type="checkbox" name="remember" id="remember">
              <span>Remember me</span>
            </label>
            <a href="/forgot-password" class="forgot-link">Forgot Password?</a>
          </div>

          <button type="submit" class="btn btn-primary" style="margin-top: 0.5rem; justify-content: center;">
            Authenticate Access
          </button>
        </form>

        <div class="signup-prompt">
          New to Aegis? <a href="/signup">Create an Account</a>
        </div>
      </div>
    </div>
  </div>
</body>
</html>
