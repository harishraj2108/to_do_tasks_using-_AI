<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content="Aegis AI is a proactive productivity companion that prioritizes tasks, auto-blocks calendar schedules, tracks habits, and features customized deep work environments with synthesized sound waves." />
  <title>Aegis AI - Deep Focus Studio</title>
  <link rel="stylesheet" href="/css/index.css">
  <link rel="stylesheet" href="/css/app.css">
  <script src="/js/app.js" defer></script>
  <script src="/js/deepwork.js" defer></script>
</head>
<body>
  <div class="app-container">
    <div class="ambient-glow-1"></div>
    <div class="ambient-glow-2"></div>

    <!-- Sidebar Navigation -->
    <aside class="sidebar">
      <div>
        <% const username = userEmail ? userEmail.split('@')[0] : 'guest' %>
        <a href="/<%= username %>/index" class="logo-section">
          <div class="logo-icon">A</div>
          <span class="logo-text">Aegis AI</span>
        </a>
        <nav>
          <ul class="nav-links">
            <li><a href="/<%= username %>/index" class="nav-item">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="7" height="9" x="3" y="3" rx="1" /><rect width="7" height="5" x="14" y="3" rx="1" /><rect width="7" height="9" x="14" y="10" rx="1" /><rect width="7" height="5" x="3" y="16" rx="1" /></svg>
              <span>Dashboard</span>
            </a></li>
            <li><a href="/<%= username %>/calendar" class="nav-item">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M8 2v4" /><path d="M16 2v4" /><rect width="18" height="18" x="3" y="4" rx="2" /><path d="M3 10h18" /></svg>
              <span>Time Blocking</span>
            </a></li>
            <li><a href="/<%= username %>/deepwork" class="nav-item active">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10" /><polygon points="10 8 16 12 10 16 10 8" /></svg>
              <span>Deep Work</span>
            </a></li>
            <li><a href="/<%= username %>/habits" class="nav-item">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22c5.523 0 10-4.477 10-10S17.523 2 12 2 2 6.477 2 12s4.477 10 10 10z" /><path d="m9 12 2 2 4-4" /></svg>
              <span>Habit Tracker</span>
            </a></li>
          </ul>
        </nav>
      </div>
      <div class="sidebar-footer">
        <div class="user-profile">
          <div class="avatar"><%= userEmail ? userEmail.split('@')[0].charAt(0).toUpperCase() : 'U' %></div>
          <div class="user-info">
            <p><%= userEmail ? userEmail.split('@')[0] : 'Guest User' %></p>
            <span>Focus Mode Active</span>
          </div>
        </div>
      </div>
    </aside>

    <!-- Main Content Area -->
    <main class="content-area">
      <header class="app-header">
        <div class="header-title-section">
          <h1>Deep Focus Studio</h1>
          <p>Immersive focus timers and custom sound wave synthesizers</p>
        </div>
      </header>

      <!-- If no task is selected for focus -->
      <div id="no-task-focus-container" style="display: flex; flex-direction: column; align-items: center; justify-content: center; flex: 1;">
        <div class="glass-card" style="max-width: 500px; width: 100%; padding: 2rem; text-align: center;">
          <h3 style="margin-bottom: 1rem; font-family: 'Space Grotesk';">Select a Task to Begin</h3>
          <p style="font-size: 0.85rem; color: var(--text-secondary); margin-bottom: 1.5rem;">
            Time-block a task in the Deep Focus Room. We will load the checklists and generate ambient frequency sounds for you.
          </p>
          <div id="uncompleted-focus-task-list" style="display: flex; flex-direction: column; gap: 0.5rem; max-height: 200px; overflow-y: auto; text-align: left;">
            <!-- Dynamically populated list of uncompleted tasks -->
          </div>
        </div>
      </div>

      <!-- Active Focus Room -->
      <div class="deepwork-view" id="active-focus-room-container" style="display: none;">
        <!-- Left Side: Circular Timer & Sound synthesizer -->
        <div class="glass-card deepwork-left">
          <div style="text-align: center;">
            <h3 style="font-family: 'Space Grotesk'; fontSize: 1.25rem; margin-bottom: 0.25rem;">Active Focus Room</h3>
            <p style="color: var(--accent-cyan); font-weight: 600; font-size: 0.9rem;" id="focus-task-title">-</p>
          </div>

          <div class="timer-circle-container">
            <svg width="240" height="240" class="timer-svg">
              <circle cx="120" cy="120" r="100" class="timer-bg-circle"></circle>
              <circle cx="120" cy="120" r="100" class="timer-progress-circle" id="timer-progress-circle-node" stroke-dashoffset="0"></circle>
            </svg>
            <div class="timer-text-container">
              <span class="timer-time" id="timer-time-display">25:00</span>
              <span class="timer-label" id="timer-status-label">PAUSED</span>
            </div>
          </div>

          <div class="timer-controls">
            <button class="btn btn-primary" id="timer-toggle-btn">▶️ Start Focus</button>
            <button class="btn" id="timer-reset-btn">🔄 Reset</button>
            <button class="btn btn-danger" id="exit-focus-session-btn">Exit Session</button>
          </div>

          <div class="sound-panel" style="border-top: 1px solid var(--border-light); padding-top: 1.5rem; margin-top: 0.5rem;">
            <h4 style="font-size: 0.9rem; font-weight: 600; color: #fff;">Ambient Audio Synthesizer</h4>
            <div class="sound-options">
              <button class="sound-btn active" data-sound="none" id="sound-btn-none">🔇 Mute</button>
              <button class="sound-btn" data-sound="brown" id="sound-btn-brown">🌊 Ocean Wave</button>
              <button class="sound-btn" data-sound="binaural" id="sound-btn-binaural">🎧 10Hz Alpha Beats</button>
            </div>

            <div class="volume-slider" id="volume-slider-container" style="display: none;">
              <span>Volume:</span>
              <input type="range" min="0" max="0.5" step="0.01" value="0.25" id="sound-volume-slider">
              <span id="sound-volume-percent-label">50%</span>
            </div>
          </div>
        </div>

        <!-- Right Side: Checklists & Complete Action -->
        <div class="deepwork-right">
          <div class="glass-card checklist-card">
            <h3 class="card-title">AI Action Plan</h3>
            <p style="font-size: 0.75rem; color: var(--text-secondary);">
              Step-by-step progress checklist generated by Aegis AI
            </p>

            <div class="checklist-items" id="focus-checklist-items">
              <!-- Dynamically populated checklist items -->
            </div>

            <button class="btn btn-primary" id="complete-main-task-btn" style="width: 100%; justify-content: center; margin-top: 1.5rem; background: linear-gradient(135deg, var(--accent-green) 0%, #059669 100%); box-shadow: 0 0 15px rgba(16, 185, 129, 0.25); color: #fff;">
              🏆 Complete Main Task
            </button>
          </div>
        </div>
      </div>
    </main>

    <!-- Floating AI voice assistant overlay and side-panel -->
    <button class="ai-toggle-floating" id="ai-toggle-btn" title="Ask Aegis AI">
      <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#000" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
        <path d="M12 2a3 3 0 0 0-3 3v7a3 3 0 0 0 6 0V5a3 3 0 0 0-3-3Z" />
        <path d="M19 10v2a7 7 0 0 1-14 0v-2" />
        <line x1="12" x2="12" y1="19" y2="22" />
      </svg>
    </button>

    <div class="ai-assistant-panel" id="ai-panel">
      <div class="ai-header">
        <div class="ai-header-title">
          <span class="pulse-indicator"></span>
          <span>Aegis Assistant</span>
        </div>
        <button style="background: transparent; border: none; cursor: pointer; font-size: 1.2rem; color: var(--text-secondary);" id="ai-panel-close-btn">
          ✕
        </button>
      </div>

      <div class="ai-body" id="ai-messages-container">
        <!-- AI chats go here -->
      </div>

      <div class="ai-footer">
        <button class="mic-btn" id="ai-mic-btn" title="Speak a command">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M12 2a3 3 0 0 0-3 3v7a3 3 0 0 0 6 0V5a3 3 0 0 0-3-3Z" />
            <path d="M19 10v2a7 7 0 0 1-14 0v-2" />
            <line x1="12" x2="12" y1="19" y2="22" />
          </svg>
        </button>
        <form class="chat-input-wrapper" id="ai-chat-form">
          <input
            type="text"
            id="ai-chat-input"
            class="chat-input"
            placeholder="e.g. Schedule my tasks today..."
          />
          <button type="submit" class="send-btn">➔</button>
        </form>
      </div>
    </div>

    <!-- Toast Notification Container -->
    <div class="toast-container" id="toast-container"></div>
  </div>
</body>
</html>
